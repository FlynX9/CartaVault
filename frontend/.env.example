# Laisser vide en local pour utiliser le proxy Vite /api vers 127.0.0.1:8000.
VITE_API_BASE_URL=
# Instance fallback used after the browser language when no account preference exists.
VITE_DEFAULT_LANGUAGE=fr
# Optional for the preserved Stadia satellite layer. This value is exposed to the browser.
VITE_STADIA_MAPS_API_KEY=
# Each provider can be removed from selectors without changing frontend code.
VITE_BASEMAP_LIGHT_ENABLED=true
VITE_BASEMAP_DARK_ENABLED=true
VITE_BASEMAP_SATELLITE_ENABLED=true
VITE_BASEMAP_OSM_ENABLED=true
# OpenFreeMap vector source and locally hosted MapLibre styles. No key is required.
VITE_BASEMAP_LIGHT_STYLE_URL=/map-styles/cartavault-light.json
VITE_BASEMAP_DARK_STYLE_URL=/map-styles/cartavault-dark.json
VITE_OPENFREEMAP_TILEJSON_URL=https://tiles.openfreemap.org/planet
VITE_OPENFREEMAP_GLYPHS_URL=https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf
# Optional preserved raster sources. OSM Standard is the controlled fallback.
VITE_BASEMAP_SATELLITE_URL=
VITE_BASEMAP_OSM_URL=
