DATABASE_URL=postgresql+psycopg://poi_user:change_me@localhost:5432/poi_manager
CARTAVAULT_VERSION=0.1.0
PHOTO_STORAGE_PATH=storage/photos
AVATAR_STORAGE_PATH=storage/avatars

# Routing (public demo server; deploy a private/managed OSRM for production)
OSRM_BASE_URL=https://router.project-osrm.org
KMZ_MAX_IMAGES=500
KMZ_MAX_ENTRIES=750
OSRM_TIMEOUT_SECONDS=12
OSRM_MAX_WAYPOINTS=50
OSRM_PROFILE=driving
# Obsolète : uniquement détectée pour avertir, jamais utilisée pour router.
GOOGLE_MAPS_ROUTES_API_KEY=
# Clé Fernet maîtresse de l’instance ; à fournir via un secret de déploiement.
CARTAVAULT_CREDENTIALS_ENCRYPTION_KEY=
GOOGLE_MAPS_ROUTES_BASE_URL=https://routes.googleapis.com
GOOGLE_MAPS_ROUTES_TIMEOUT_SECONDS=15
GOOGLE_MAPS_ROUTES_CONNECT_TIMEOUT_SECONDS=5
GOOGLE_MAPS_ROUTING_PREFERENCE=TRAFFIC_UNAWARE
GOOGLE_MAPS_AVOID_TOLLS=false
GOOGLE_MAPS_AVOID_HIGHWAYS=false
GOOGLE_MAPS_AVOID_FERRIES=false
TEST_DATABASE_URL=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CARTAVAULT_SESSION_COOKIE_NAME=cartavault_session
CARTAVAULT_CSRF_COOKIE_NAME=cartavault_csrf
CARTAVAULT_SESSION_DAYS=14
CARTAVAULT_INVITATION_HOURS=168
CARTAVAULT_COOKIE_SECURE=false
CARTAVAULT_PASSWORD_MIN_LENGTH=12
CARTAVAULT_ARGON2_TIME_COST=3
CARTAVAULT_ARGON2_MEMORY_COST=65536
CARTAVAULT_ARGON2_PARALLELISM=4
# Bootstrap non interactif optionnel. Ne jamais versionner de vraies valeurs.
CARTAVAULT_BOOTSTRAP_ADMIN_EMAIL=
CARTAVAULT_BOOTSTRAP_ADMIN_NAME=
CARTAVAULT_BOOTSTRAP_ADMIN_PASSWORD=
EMAIL_PROVIDER=resend
EMAIL_FROM_NAME=CartaVault
EMAIL_FROM_ADDRESS=no-reply@cartavault.fr
EMAIL_REPLY_TO=contact@cartavault.fr
FRONTEND_PUBLIC_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_PROVIDER_TIMEOUT_SECONDS=10
