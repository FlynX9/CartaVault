DATABASE_URL=postgresql+psycopg://poi_user:change_me@localhost:5432/poi_manager
PHOTO_STORAGE_PATH=storage/photos
AVATAR_STORAGE_PATH=storage/avatars

# Routing (public demo server; deploy a private/managed OSRM for production)
OSRM_BASE_URL=https://router.project-osrm.org
KMZ_MAX_IMAGES=500
KMZ_MAX_ENTRIES=750
OSRM_TIMEOUT_SECONDS=12
OSRM_MAX_WAYPOINTS=50
OSRM_PROFILE=driving
TEST_DATABASE_URL=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CARTAVAULT_SESSION_COOKIE_NAME=cartavault_session
CARTAVAULT_CSRF_COOKIE_NAME=cartavault_csrf
CARTAVAULT_SESSION_DAYS=14
CARTAVAULT_INVITATION_HOURS=168
CARTAVAULT_COOKIE_SECURE=false
CARTAVAULT_PASSWORD_MIN_LENGTH=12
CARTAVAULT_ARGON2_TIME_COST=3
CARTAVAULT_ARGON2_MEMORY_COST=65536
CARTAVAULT_ARGON2_PARALLELISM=4
# Bootstrap non interactif optionnel. Ne jamais versionner de vraies valeurs.
CARTAVAULT_BOOTSTRAP_ADMIN_EMAIL=
CARTAVAULT_BOOTSTRAP_ADMIN_NAME=
CARTAVAULT_BOOTSTRAP_ADMIN_PASSWORD=
